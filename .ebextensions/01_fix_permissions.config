container_commands:
  01_fix_permissions:
    command: |
      # Directly use /var/app/current instead of symlink
      chown -R apache:apache /var/app/current
      chmod -R 755 /var/app/current
      chmod 644 /var/app/current/index.php
      chmod 644 /var/app/current/index.html
      chmod 644 /var/app/current/.htaccess
      
      # Update Apache config to point to /var/app/current
      echo 'DocumentRoot "/var/app/current"' > /etc/httpd/conf.d/00_documentroot.conf
      
      # Restart Apache
      systemctl restart httpd
