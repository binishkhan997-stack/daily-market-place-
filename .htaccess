# SIMPLE .htaccess - NO REDIRECTS
DirectoryIndex index.php index.html

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /
    
    # If the request is not for a valid file or directory
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ index.php [QSA,L]
</IfModule>

# Allow directory listing (temporarily for debugging)
Options +Indexes

# Allow access to all files (temporarily)
<FilesMatch ".*">
    Order Allow,Deny
    Allow from all
</FilesMatch>
